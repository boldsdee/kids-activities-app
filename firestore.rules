rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an admin
    // This looks at the `isAdmin` boolean field in the user's profile document
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // 1. User Profiles Collection
    match /users/{userId} {
      // Anyone can read their own profile, Admins can read everyone's profile
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Allow user creation, but strictly prevent them from making themselves Pro or Admin
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.get('isAdmin', false) == false
                    && request.resource.data.get('isPro', false) == false;
      
      // Allow users to update their profile, but ensure they cannot toggle Admin or Pro fields
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false)
                    && request.resource.data.get('isPro', false) == resource.data.get('isPro', false);

      // Admins can create/update/delete any user document without restrictions
      allow write: if isAdmin();
      
      // 2. User Planner Data Subcollection (Schedules, Favorites, Custom Activities)
      match /plannerData/{document=**} {
        // Users can only read and write their own planner data, Admins can read/write everything
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    } // Close match /users/{userId}
      
    // 3. Stripe Extension Collections (Default configured to 'customers')
    match /customers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      match /checkout_sessions/{id} {
        // Users can create checkout sessions for themselves to pay
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /subscriptions/{id} {
        // Users can only read their own subscriptions
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // 4. Products Collection (Auto-generated by the Firebase Stripe Extension)
    match /products/{id} {
      allow read: if true; // Anyone can read products to see pricing
      match /prices/{id} {
        allow read: if true;
      }
    }
  }
}
